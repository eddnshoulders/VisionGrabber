[Unit]
Description=VisionGrabber OpenCV + Web UI Service
After=network.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/VisionGrabber
ExecStart=/home/pi/VisionGrabber/grabber-venv/bin/python -u /home/pi/VisionGrabber/flask_app.py
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
